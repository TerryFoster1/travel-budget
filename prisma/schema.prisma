// Prisma schema planning placeholder for PostgreSQL.
// Final models are intentionally not defined yet.
// Add real fields, relations, indexes, and constraints only after the database plan is approved.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

